# Lumen per-chat MCP sandbox image
# Build once per machine, or whenever this file changes:
#   docker build -f Dockerfile.sandbox -t lumen-sandbox .

FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    bash \
    curl \
    git \
    ca-certificates \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3 /usr/bin/python

WORKDIR /workspace
CMD ["sleep", "infinity"]
